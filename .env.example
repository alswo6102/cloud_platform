# Local-only deployment settings. Copy to .env.local and edit.

NCP_HOST=203.0.113.10
NCP_USER=ubuntu
NCP_PORT=22

# password or key
NCP_AUTH_METHOD=password
NCP_PASSWORD=change-me

# Only used when NCP_AUTH_METHOD=key
NCP_SSH_KEY=~/.ssh/ncp-demo.pem

REMOTE_DIR=/opt/cloud_platform
REMOTE_APP=admin.py
REMOTE_PORT=8501
REMOTE_PROJECTS_ROOT=/srv/projects

# Optional: service name used by systemd scripts later.
REMOTE_SERVICE_NAME=cloud-platform-dashboard
REMOTE_AGENT_NAME=cloud-platform-skill-agent

# Optional OpenAI-compatible chat-completions API.
# Leave blank to use deterministic Skill mode.
LLM_API_KEY=
LLM_API_URL=
# Preferred order. A model returning HTTP 429 is temporarily skipped.
LLM_MODELS=gemini-3.1-flash-lite,gemini-3-flash-preview,gemini-2.5-flash,gemini-2.5-flash-lite
# Legacy single-model fallback when LLM_MODELS is blank.
LLM_MODEL=
